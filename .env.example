# Application Port Mapping
PORT=5000

# Security (Change this in production)
JWT_SECRET=supersecretkey123_bharattourism

# PostgreSQL Database Connection String
# When running with Docker Compose, the host is 'db' (the postgres service name)
DATABASE_URL=postgresql://postgres:password@db:5432/travel_booking?schema=public

# If running the backend manually on your host machine (without Docker), use localhost:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/travel_booking?schema=public
